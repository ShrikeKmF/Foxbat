# ──────────────────────────────────────────────
# Foxbat — Environment Variable Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to GitHub.
# ──────────────────────────────────────────────

# Discord
DISCORD_TOKEN=your-bot-token-here
CLIENT_ID=your-application-client-id
GUILD_ID=your-discord-server-id

# Channels
VOICE_CHANNEL_ID=your-contractor-count-voice-channel-id
LOG_CHANNEL_ID=your-log-channel-id
HR_CHANNEL_ID=your-hr-channel-id

# Google Sheets
RTG_ORBAT_ID=your-google-sheet-id

# Google Service Account credentials (the entire contents of credentials.json, as one line)
# To generate: python -c "import json,sys; print(json.dumps(json.load(open('credentials.json'))))"
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
